generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Institution {
  id                           String         @id @default(uuid())
  nom                          String
  sigle                        String?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  logoUrl                      String?
  tamponDirecteurUrl           String?
  tamponDirecteurAdjointUrl    String?
  directeurNom                 String?
  directeurTitre               String?
  directeurAdjointNom          String?
  directeurAdjointTitre        String?
  signatureDirecteurUrl        String?
  signatureDirecteurAdjointUrl String?
  demandes                     Demande[]
  pieceRequises                PieceRequise[]
  utilisateurs                 Utilisateur[]
}

model Utilisateur {
  id                   String                   @id @default(uuid())
  nom                  String
  prenom               String
  email                String                   @unique
  password             String
  role                 Role                     @default(ETUDIANT)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  institutionId        String?
  numeroEtudiant       String?                  @unique
  service              Service?
  actif                Boolean                  @default(true)
  emailVerifie         Boolean                  @default(false)
  tokenVerification    String?
  tokenResetPassword   String?
  tokenResetExpiry     DateTime?
  filiere              String?
  niveau               String?
  demandes             Demande[]
  piecesValidees       PieceJustificative[]     @relation("PieceValideePar")
  institution          Institution?             @relation(fields: [institutionId], references: [id])
  actionsWorkflow      WorkflowHistory[]        @relation("ActorWorkflow")
  notifications        Notification[]
  reclamationsEtudiant Reclamation[]            @relation("ReclamationsEtudiant")
  reclamationsTraitees Reclamation[]            @relation("ReclamationsTraitees")
}

model Demande {
  id              String               @id @default(uuid())
  reference       String?              @unique
  typeDocument    TypeDocument
  semestres       Int[]
  anneeAcademique String?
  serviceCible    Service
  statut          StatutDemande        @default(SOUMISE)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deliveredAt     DateTime?
  utilisateurId   String
  institutionId   String
  institution     Institution          @relation(fields: [institutionId], references: [id])
  utilisateur     Utilisateur          @relation(fields: [utilisateurId], references: [id])
  documents       Document[]
  pieces          PieceJustificative[]
  historique      WorkflowHistory[]
  notifications   Notification[]
}

model WorkflowHistory {
  id          String        @id @default(uuid())
  statut      StatutDemande
  commentaire String?
  createdAt   DateTime      @default(now())
  demandeId   String
  actorId     String?
  actor       Utilisateur?  @relation("ActorWorkflow", fields: [actorId], references: [id])
  demande     Demande       @relation(fields: [demandeId], references: [id])
}

model Document {
  id               String                   @id @default(uuid())
  reference        String                   @unique
  qrPayload        String                   @unique
  urlPdf           String
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  deliveredAt      DateTime?
  statut           StatutDocument           @default(DOCUMENT_GENERE)
  signedByDAAt     DateTime?
  signedByDIRAt    DateTime?
  generationSource GenerationSource         @default(DEMANDE_INITIALE)
  remplaceParId    String?                  @unique
  remplacePar      Document?                @relation("Remplacement", fields: [remplaceParId], references: [id], onDelete: SetNull)
  remplace         Document?                @relation("Remplacement")
  demandeId        String
  demande          Demande                  @relation(fields: [demandeId], references: [id])
  reclamations     Reclamation[]            @relation("ReclamationDocument")
  corrections      Reclamation[]            @relation("DocumentCorrigeReclamation")
}

model Reclamation {
  id                String            @id @default(uuid())
  documentId        String
  document          Document          @relation("ReclamationDocument", fields: [documentId], references: [id])
  etudiantId        String
  etudiant          Utilisateur       @relation("ReclamationsEtudiant", fields: [etudiantId], references: [id])
  type              ReclamationType
  description       String            @db.Text
  piecesJointes     String[]
  statut            ReclamationStatut @default(EN_ATTENTE)
  traiteParId       String?
  traitePar         Utilisateur?      @relation("ReclamationsTraitees", fields: [traiteParId], references: [id])
  reponseAgent      String?           @db.Text
  documentCorrigeId String?
  documentCorrige   Document?         @relation("DocumentCorrigeReclamation", fields: [documentCorrigeId], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  resolvedAt        DateTime?

  @@index([documentId])
  @@index([etudiantId])
  @@index([traiteParId])
  @@index([statut])
}

model PieceJustificative {
  id           String       @id @default(uuid())
  typePiece    TypePiece
  nom          String
  url          String
  quittanceFingerprint String?      @unique
  ocrStatut    String?
  ocrTexte     String?      @db.Text
  createdAt    DateTime     @default(now())
  statut       StatutPiece  @default(SOUMISE)
  commentaire  String?
  valideeAt    DateTime?
  valideeParId String?
  demandeId    String
  demande      Demande      @relation(fields: [demandeId], references: [id])
  valideePar   Utilisateur? @relation("PieceValideePar", fields: [valideeParId], references: [id])
}

model PieceRequise {
  id            String       @id @default(uuid())
  typeDocument  TypeDocument
  typePiece     TypePiece
  obligatoire   Boolean      @default(true)
  institutionId String
  institution   Institution  @relation(fields: [institutionId], references: [id])

  @@unique([institutionId, typeDocument, typePiece])
}

model Notification {
  id            String      @id @default(uuid())
  utilisateurId String
  utilisateur   Utilisateur @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  type          String
  titre         String
  message       String
  lien          String?
  lue           Boolean     @default(false)
  demandeId     String?
  demande       Demande?    @relation(fields: [demandeId], references: [id], onDelete: SetNull)
  createdAt     DateTime    @default(now())
}

enum Service {
  EXAMENS
  SCOLARITE
}

enum Role {
  ETUDIANT
  SECRETAIRE_ADJOINT
  SECRETAIRE_GENERAL
  CHEF_DIVISION
  DIRECTEUR_ADJOINT
  DIRECTEUR
  SUPER_ADMIN
}

enum TypeDocument {
  ATTESTATION_INSCRIPTION
  RELEVE_NOTES
}

enum StatutDemande {
  SOUMISE
  CORRECTION_DEMANDEE
  TRANSMISE_SECRETAIRE_ADJOINT
  TRANSMISE_SECRETAIRE_GENERAL
  DOCUMENT_GENERE
  ATTENTE_VALIDATION_DA
  ATTENTE_SIGNATURE_DIRECTEUR
  DISPONIBLE
  REJETEE
  ANNULEE
}

enum StatutDocument {
  DOCUMENT_GENERE
  ATTENTE_SIGNATURE_DIRECTEUR
  DISPONIBLE
  REMPLACE
  REJETEE
}

enum TypePiece {
  CIP
  QUITTANCE
  ACTE_NAISSANCE
  JUSTIFICATIF_INSCRIPTION
}

enum StatutPiece {
  SOUMISE
  VALIDEE
  REJETEE
}

enum ReclamationType {
  ERREUR_IDENTITE
  ERREUR_NOTES
  ERREUR_SEMESTRE
  ERREUR_NIVEAU
  ERREUR_INSTITUTION
  DOCUMENT_ILLISIBLE
  AUTRE
}

enum ReclamationStatut {
  EN_ATTENTE
  EN_COURS
  RESOLUE_DOC_REGENERE
  RESOLUE_SANS_DOC
  REJETEE
}

enum GenerationSource {
  DEMANDE_INITIALE
  RECLAMATION
}
