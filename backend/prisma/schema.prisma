generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Institution {
  id                           String         @id @default(uuid())
  nom                          String
  sigle                        String?
  createdAt                    DateTime       @default(now())
  updatedAt                    DateTime       @updatedAt
  logoUrl                      String?
  tamponDirecteurUrl           String?
  tamponDirecteurAdjointUrl    String?
  directeurNom                 String?
  directeurTitre               String?
  directeurAdjointNom          String?
  directeurAdjointTitre        String?
  signatureDirecteurUrl        String?
  signatureDirecteurAdjointUrl String?
  demandes                     Demande[]
  pieceRequises                PieceRequise[]
  utilisateurs                 Utilisateur[]
}

model Utilisateur {
  id                 String               @id @default(uuid())
  nom                String
  prenom             String
  email              String               @unique
  password           String
  role               Role                 @default(ETUDIANT)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  institutionId      String?
  numeroEtudiant     String?              @unique
  service            Service?
  actif              Boolean              @default(true)
  emailVerifie       Boolean              @default(false)
  tokenVerification  String?
  tokenResetPassword String?
  tokenResetExpiry   DateTime?
  filiere            String?
  niveau             String?
  demandes           Demande[]
  piecesValidees     PieceJustificative[] @relation("PieceValideePar")
  institution        Institution?         @relation(fields: [institutionId], references: [id])
  actionsWorkflow    WorkflowHistory[]    @relation("ActorWorkflow")
  notifications      Notification[]
}

model Demande {
  id              String               @id @default(uuid())
  reference       String?              @unique
  typeDocument    TypeDocument
  semestres       Int[]
  anneeAcademique String?
  serviceCible    Service
  statut          StatutDemande        @default(SOUMISE)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deliveredAt     DateTime?
  utilisateurId   String
  institutionId   String
  institution     Institution          @relation(fields: [institutionId], references: [id])
  utilisateur     Utilisateur          @relation(fields: [utilisateurId], references: [id])
  documents       Document[]
  pieces          PieceJustificative[]
  historique      WorkflowHistory[]
  notifications   Notification[]
}

model WorkflowHistory {
  id          String        @id @default(uuid())
  statut      StatutDemande
  commentaire String?
  createdAt   DateTime      @default(now())
  demandeId   String
  actorId     String?
  actor       Utilisateur?  @relation("ActorWorkflow", fields: [actorId], references: [id])
  demande     Demande       @relation(fields: [demandeId], references: [id])
}

model Document {
  id            String         @id @default(uuid())
  reference     String         @unique
  qrPayload     String         @unique
  urlPdf        String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  deliveredAt   DateTime?
  statut        StatutDocument @default(DOCUMENT_GENERE)
  signedByDAAt  DateTime?
  signedByDIRAt DateTime?
  downloadCount Int            @default(0)
  maxDownloads  Int            @default(3)
  blockedAt     DateTime?
  demandeId     String
  demande       Demande        @relation(fields: [demandeId], references: [id])
}

model PieceJustificative {
  id           String       @id @default(uuid())
  typePiece    TypePiece
  nom          String
  url          String
  createdAt    DateTime     @default(now())
  statut       StatutPiece  @default(SOUMISE)
  commentaire  String?
  valideeAt    DateTime?
  valideeParId String?
  demandeId    String
  demande      Demande      @relation(fields: [demandeId], references: [id])
  valideePar   Utilisateur? @relation("PieceValideePar", fields: [valideeParId], references: [id])
}

model PieceRequise {
  id            String       @id @default(uuid())
  typeDocument  TypeDocument
  typePiece     TypePiece
  obligatoire   Boolean      @default(true)
  institutionId String
  institution   Institution  @relation(fields: [institutionId], references: [id])

  @@unique([institutionId, typeDocument, typePiece])
}

model Notification {
  id            String       @id @default(uuid())
  utilisateurId String
  utilisateur   Utilisateur  @relation(fields: [utilisateurId], references: [id], onDelete: Cascade)
  type          String
  titre         String
  message       String
  lien          String?
  lue           Boolean      @default(false)
  demandeId     String?
  demande       Demande?     @relation(fields: [demandeId], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

enum Service {
  EXAMENS
  SCOLARITE
}

enum Role {
  ETUDIANT
  SECRETAIRE_ADJOINT
  SECRETAIRE_GENERAL
  CHEF_DIVISION
  DIRECTEUR_ADJOINT
  DIRECTEUR
  SUPER_ADMIN
}

enum TypeDocument {
  ATTESTATION_INSCRIPTION
  RELEVE_NOTES
}

enum StatutDemande {
  SOUMISE
  CORRECTION_DEMANDEE
  TRANSMISE_SECRETAIRE_ADJOINT
  TRANSMISE_SECRETAIRE_GENERAL
  DOCUMENT_GENERE
  ATTENTE_VALIDATION_DA
  ATTENTE_SIGNATURE_DIRECTEUR
  DISPONIBLE
  REJETEE
  ANNULEE
}

enum StatutDocument {
  DOCUMENT_GENERE
  ATTENTE_SIGNATURE_DIRECTEUR
  DISPONIBLE
  REJETEE
}

enum TypePiece {
  CIP
  QUITTANCE
  ACTE_NAISSANCE
  JUSTIFICATIF_INSCRIPTION
}

enum StatutPiece {
  SOUMISE
  VALIDEE
  REJETEE
}
